{
  "uid": "error-rates",
  "title": "Error Rates",
  "description": "Error rate monitoring for the MarkFlow FastAPI application",
  "tags": ["markflow", "errors", "loki"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Error Count Over Time",
      "description": "Count of warning, error, and critical log entries over time, grouped by level",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({service=\"markflow\"} | json | level=~\"warning|error|critical\" [1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Count",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "title": "Error Rate Percentage",
      "description": "Percentage of log entries that are errors or critical over the last 5 minutes",
      "type": "stat",
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "errors",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"markflow\"} | json | level=~\"error|critical\" [5m]))",
          "legendFormat": "errors"
        },
        {
          "refId": "total",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"markflow\"} | json [5m]))",
          "legendFormat": "total"
        }
      ],
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "alias": "Error Rate %",
            "binary": {
              "left": "errors",
              "operator": "/",
              "right": "total",
              "reducer": "sum"
            },
            "mode": "binary",
            "reduce": { "reducer": "sum" }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Error Rate Pct",
            "binary": {
              "left": "Error Rate %",
              "operator": "*",
              "right": "100"
            },
            "mode": "binary",
            "reduce": { "reducer": "sum" }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "names": ["Error Rate Pct"] }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Responses",
      "description": "Count of HTTP responses with status code >= 400, split by status code",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (status_code) (count_over_time({service=\"markflow\"} | json | status_code >= 400 [1m]))",
          "legendFormat": "{{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Count",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "title": "Top Error Messages",
      "description": "Top 10 most frequent error and critical events in the last hour",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(10, sum by (event) (count_over_time({service=\"markflow\"} | json | level=~\"error|critical\" [1h])))",
          "legendFormat": "",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "Value", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "event" },
            "properties": [
              { "id": "custom.width", "value": 400 },
              { "id": "displayName", "value": "Error Event" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Count" },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      }
    },
    {
      "id": 5,
      "title": "Errors by Endpoint",
      "description": "Error and critical log counts grouped by request path",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(20, sum by (path) (count_over_time({service=\"markflow\"} | json | level=~\"error|critical\" [1h])))",
          "legendFormat": "",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "Value", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "path" },
            "properties": [
              { "id": "custom.width", "value": 350 },
              { "id": "displayName", "value": "Endpoint Path" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Error Count" },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "sortBy": [{ "desc": true, "displayName": "Error Count" }]
      }
    },
    {
      "id": 6,
      "title": "Recent Errors",
      "description": "Last 50 error and critical log entries with full JSON detail",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"markflow\"} | json | level=~\"error|critical\"",
          "maxLines": 50
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [],
  "liveNow": false,
  "version": 1
}
